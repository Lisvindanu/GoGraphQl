type PenginapanItem {
  id: String!
  nama: String!
  tipe: String!
  alamat: String
  bintang: String
  telepon: String
  website: String
  lat: Float!
  lon: Float!
}

extend type Query {
  """Daftar hotel/penginapan berdasarkan nama kota (via OpenStreetMap)"""
  penginapan(kota: String!): [PenginapanItem!]!
}
